    "eslint-plugin-prefer-arrow-functions": "3.3.2",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "10.4.0",
